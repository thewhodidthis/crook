{
  "name": "@thewhodidthis/crook",
  "version": "0.0.1",
  "description": "Helps with pixel shifting",
  "keywords": [
    "canvas",
    "pixels",
    "shifting"
  ],
  "main": "index.js",
  "module": "index.es",
  "homepage": "https://github.com/thewhodidthis/crook#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thewhodidthis/crook.git"
  },
  "bugs": {
    "url": "https://github.com/thewhodidthis/crook/issues"
  },
  "directories": {
    "example": "example"
  },
  "config": {
    "remote": "thewhodidthis@zazie:www/example/crook/"
  },
  "scripts": {
    "test": "node test",
    "lint": "eslint index.es test/*.js",
    "start": "rollup -c && uglifyjs dist/crook.js -cmo dist/crook.min.js",
    "preexample": "npm start",
    "example": "npm run example:link && npm run example:serve",
    "example:link": "ln -siv \"$(pwd)/dist/crook.min.js\" example/crook.js",
    "example:serve": "php -S localhost:8000 -t example/",
    "example:push": "rsync -avruzLPC --exclude=.DS_Store ./example/ $npm_package_config_remote"
  },
  "engines": {
    "node": ">=4.2.4",
    "npm": ">=3.5.3"
  },
  "dependencies": {},
  "devDependencies": {
    "babel-eslint": "latest",
    "babel-plugin-external-helpers": "latest",
    "babel-preset-es2015": "latest",
    "browserify": "latest",
    "eslint": "^3.19.0",
    "eslint-config-airbnb-base": "latest",
    "eslint-plugin-import": "latest",
    "rollup": "latest",
    "rollup-plugin-babel": "latest",
    "tape": "latest",
    "testling": "latest",
    "uglify-js": "latest"
  },
  "author": "sChzs BkgNns <sotirios.bakagiannis@gmail.com> (https://www.thewhodidthis.com)",
  "license": "Unlicense"
}
