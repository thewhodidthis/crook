{
  "name": "@thewhodidthis/crook",
  "version": "1.0.3",
  "description": "Helps with pixel shifting",
  "main": "index.js",
  "module": "index.es",
  "homepage": "https://github.com/thewhodidthis/crook#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thewhodidthis/crook.git"
  },
  "bugs": {
    "url": "https://github.com/thewhodidthis/crook/issues"
  },
  "scripts": {
    "pretest": "eslint test.js",
    "test": "rollup -c node:x -f iife test.js | kpow",
    "prestart": "eslint index.es",
    "start": "rollup -f cjs index.es > index.js",
    "poststart": "rollup -f iife -n crook index.es | buble > example/crook.js",
    "preexample": "eslint example/index.es",
    "example": "cd example; rollup -f iife index.es | buble > index.js",
    "postexample": "open http://localhost:8000; php -S localhost:8000 -t example/"
  },
  "eslintConfig": {
    "extends": "@thewhodidthis",
    "globals": {
      "Int32Array": true
    }
  },
  "engines": {
    "node": ">=4.2.4",
    "npm": ">=3.5.3"
  },
  "dependencies": {},
  "devDependencies": {
    "@thewhodidthis/eslint-config": "latest",
    "buble": "latest",
    "cutaway": "latest",
    "eslint": "latest",
    "kpow": "latest",
    "rollup": "latest",
    "rollup-config-x": "latest",
    "tapeless": "latest"
  },
  "author": "sChzs BkgNns <sotirios.bakagiannis@gmail.com> (https://www.thewhodidthis.com)",
  "license": "Unlicense"
}
